<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#26DD59" />
            <corners android:radius="34dp" />
        </shape>
    </item>

    <item
        android:left="11dp"
        android:top="11dp"
        android:right="11dp"
        android:bottom="11dp">
        <shape android:shape="oval">
            <stroke
                android:width="7.5dp"
                android:color="#FFFFFFFF" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>

    <item
        android:left="17dp"
        android:top="71dp"
        android:right="55dp"
        android:bottom="16dp">
        <rotate android:fromDegrees="30" android:toDegrees="30">
            <shape android:shape="rectangle">
                <solid android:color="#FFFFFFFF" />
                <corners android:radius="11dp" />
            </shape>
        </rotate>
    </item>

    <item
        android:left="47dp"
        android:top="27dp"
        android:right="47dp"
        android:bottom="43dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFFFF" />
            <corners android:radius="10dp" />
        </shape>
    </item>

    <item
        android:left="36dp"
        android:top="49dp"
        android:right="47dp"
        android:bottom="31dp">
        <rotate android:fromDegrees="45" android:toDegrees="45">
            <shape android:shape="rectangle">
                <solid android:color="#FFFFFFFF" />
                <corners android:radius="10dp" />
            </shape>
        </rotate>
    </item>

    <item
        android:left="47dp"
        android:top="49dp"
        android:right="36dp"
        android:bottom="31dp">
        <rotate android:fromDegrees="-45" android:toDegrees="-45">
            <shape android:shape="rectangle">
                <solid android:color="#FFFFFFFF" />
                <corners android:radius="10dp" />
            </shape>
        </rotate>
    </item>

    <item
        android:left="35dp"
        android:top="71dp"
        android:right="35dp"
        android:bottom="19dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFFFF" />
            <corners android:radius="10dp" />
        </shape>
    </item>
</layer-list>
