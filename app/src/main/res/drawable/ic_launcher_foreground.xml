            <shape android:shape="rectangle">
                <solid android:color="#FFFFFFFF" />
                <corners android:radius="9dp" />
            </shape>
        </rotate>
    </item>

    <item
        android:left="28dp"
        android:top="73dp"
        android:right="28dp"
        android:bottom="17dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFFFF" />
