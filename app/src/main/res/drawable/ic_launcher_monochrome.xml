<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:left="18dp"
        android:top="18dp"
        android:right="18dp"
        android:bottom="18dp">
        <shape android:shape="oval">
            <stroke
                android:width="8dp"
                android:color="#FFFFFFFF" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>

    <item
        android:left="47dp"
        android:top="30dp"
        android:right="47dp"
        android:bottom="44dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFFFF" />
            <corners android:radius="9dp" />
        </shape>
    </item>

    <item
        android:left="34dp"
        android:top="48dp"
        android:right="47dp"
        android:bottom="31dp">
        <rotate android:fromDegrees="45" android:toDegrees="45">
            <shape android:shape="rectangle">
                <solid android:color="#FFFFFFFF" />
                <corners android:radius="9dp" />
            </shape>
        </rotate>
    </item>

    <item
        android:left="47dp"
        android:top="48dp"
        android:right="34dp"
        android:bottom="31dp">
        <rotate android:fromDegrees="-45" android:toDegrees="-45">
            <shape android:shape="rectangle">
                <solid android:color="#FFFFFFFF" />
                <corners android:radius="9dp" />
            </shape>
        </rotate>
    </item>

    <item
        android:left="28dp"
        android:top="73dp"
        android:right="28dp"
        android:bottom="17dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFFFF" />
            <corners android:radius="9dp" />
        </shape>
    </item>
</layer-list>
